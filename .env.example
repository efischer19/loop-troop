# Core repository settings
LOOP_TROOP_REPO=owner/repo
LOOP_TROOP_REPO_PATH=.
LOOP_TROOP_DB_PATH=~/.loop-troop/shadow.db

# GitHub API settings
LOOP_TROOP_GITHUB_BASE_URL=https://api.github.com

# GitHub auth: choose ONE mode.
# Option A: Personal access token (simple local setup)
GITHUB_PAT=

# Option B: GitHub App (recommended for shared/team setups)
LOOP_TROOP_APP_ID=
LOOP_TROOP_APP_PRIVATE_KEY_PATH=
LOOP_TROOP_APP_INSTALLATION_ID=

# Ollama connectivity
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=ollama

# Default models by worker tier
LOOP_TROOP_T1_MODEL=qwen2.5-coder:7b
LOOP_TROOP_T2_MODEL=qwen2.5-coder:14b
LOOP_TROOP_T3_MODEL=qwen2.5-coder:32b

# Daemon behavior
LOOP_TROOP_POLL_INTERVAL=30
LOOP_TROOP_ZOMBIE_SWEEP_INTERVAL=300
LOOP_TROOP_ZOMBIE_TIMEOUT=900
LOOP_TROOP_LOG_LEVEL=INFO
